# ────────────────────────────────────────────────────────────────────────────
# Multi-Agent Email Threat Analysis System – Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env          (Linux/Mac)
#   copy .env.example .env        (Windows)
# ────────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=change-me-use-a-strong-32char-secret-key

# Demo data seeding (optional)
SEED_DEMO_DATA=false
SEED_DEMO_TRUNCATE=false
SEED_DEMO_REPEAT=1
SEED_DEMO_HOURS_STEP=6

# API Authentication (machine-to-machine)
ALLOWED_API_KEYS=["change-me-api-key"]

# Dashboard Authentication
DASHBOARD_USERNAME=change-me-username
DASHBOARD_PASSWORD=change-me-password
DASHBOARD_SESSION_TTL_MINUTES=480

# ─── CORS ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:8080","https://yourdomain.com"]

# PostgreSQL
POSTGRES_DB=change-me-db
POSTGRES_USER=change-me-user
POSTGRES_PASSWORD=change-me-password
DATABASE_URL=postgresql+asyncpg://change-me-user:change-me-password@postgres:5432/change-me-db

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Neo4j Graph Database ─────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=change-me-neo4j-user
NEO4J_PASSWORD=change-me-neo4j-password

# ─── Celery (Task Queue) ──────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── LLM Provider (choose ONE) ────────────────────────────────────────────
#
# OPTION A – OpenRouter (RECOMMENDED – free OSS models, no credit card)
# -----------------------------------------------------------------------
# 1. Sign up free at https://openrouter.ai
# 2. Go to Dashboard → Keys → "Create Key"
# 3. Paste the key below (starts with sk-or-v1-...)
# 4. Choose a free model from the list below
#
# Free models available on OpenRouter (as of 2025):
#   google/gemma-3-27b-it:free      ← default (excellent for email analysis)
#   google/gemma-3-12b-it:free
#   meta-llama/llama-4-scout:free
#   meta-llama/llama-4-maverick:free
#   microsoft/phi-4-reasoning:free
#   microsoft/phi-4-reasoning-plus:free
#   thudm/glm-z1-32b:free           ← GLM (Chinese / bilingual)
#   thudm/glm-4-32b:free
#   mistralai/mistral-7b-instruct:free
#   qwen/qwen3-235b-a22b:free
#   deepseek/deepseek-r1:free
#   nvidia/llama-3.3-nemotron-super-49b-v1:free
#
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_MODEL=google/gemma-3-27b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8080
OPENROUTER_SITE_NAME=Email Threat Analysis

# OPTION B – OpenAI (paid, comment out if using OpenRouter)
# -----------------------------------------------------------------------
# If BOTH keys are set, OpenRouter takes priority.
#OPENAI_API_KEY=sk-your-openai-api-key-here
#OPENAI_MODEL=gpt-4o-mini

# ─── Threat Intelligence ──────────────────────────────────────────────────
# VirusTotal – free tier: 500 requests/day
# Sign up: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# PhishTank – free with API key
# Sign up: https://www.phishtank.com/register.php
PHISHTANK_API_KEY=your-phishtank-api-key

# Additional threat intelligence feeds (optional)
THREAT_FEED_URLS=[]
THREAT_FEED_API_KEY=your-threat-feed-api-key

# URLhaus (Abuse.ch) URL intelligence feed
URLHAUS_API_URL=https://urlhaus-api.abuse.ch/v1/url/

# OpenPhish feed (optional) - set if you have access
OPENPHISH_FEED_URL=
OPENPHISH_FEED_TTL_SECONDS=1800

# AbuseIPDB (IP reputation) - optional
ABUSEIPDB_API_KEY=
ABUSEIPDB_BASE_URL=https://api.abuseipdb.com/api/v2/check

# ─── Email Provider Integration (optional) ────────────────────────────────
# Gmail live integration (requires access token for Gmail API)
GMAIL_ACCESS_TOKEN=your-gmail-access-token
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_TOKEN_URI=https://oauth2.googleapis.com/token
GMAIL_USER_ID=me
GMAIL_WEBHOOK_TOKEN=your-gmail-webhook-token

# Microsoft 365 webhook validation (future use)
MICROSOFT_WEBHOOK_TOKEN=your-microsoft-webhook-token

# OAuth credentials if you are managing token refresh yourself
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
MICROSOFT_CLIENT_ID=your-ms-client-id
MICROSOFT_CLIENT_SECRET=your-ms-client-secret
MICROSOFT_TENANT_ID=your-ms-tenant-id

# ─── SOAR Integration (optional) ─────────────────────────────────────────
SOAR_WEBHOOK_URL=https://your-soar-platform.com/webhook
SOAR_API_KEY=your-soar-api-key

# ─── Analysis Thresholds ──────────────────────────────────────────────────
HIGH_RISK_THRESHOLD=0.75
MEDIUM_RISK_THRESHOLD=0.45
ANALYSIS_TIMEOUT_SECONDS=30
RATE_LIMIT_PER_MINUTE=60

# ─── Sandbox Detonation (optional) ─────────────────────────────────────────
SANDBOX_BASE_URL=https://your-sandbox.example.com
SANDBOX_API_KEY=your-sandbox-api-key
SANDBOX_TIMEOUT_SECONDS=20
SANDBOX_DETONATION_THRESHOLD=0.6

# ─── Multilingual Detection ───────────────────────────────────────────────
MULTILINGUAL_DETECTION_ENABLED=true

# ─── Custom ML Models ─────────────────────────────────────────────────────
ML_MODEL_DIR=/app/ml_models
ML_PHISHING_THRESHOLD=0.5
ML_LLM_DETECT_THRESHOLD=0.5

# ─── RLHF Pipeline ────────────────────────────────────────────────────────
RLHF_MIN_EXAMPLES=10
RLHF_TRAIN_INTERVAL_HOURS=6
RLHF_LEARNING_RATE=0.0005
RLHF_EPOCHS=15

# ─── Monitoring ───────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change-me-grafana-password
