# ────────────────────────────────────────────────────────────────────────────
# Multi-Agent Email Threat Analysis System - Environment Configuration
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────────────────────

# App
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=changeme-use-a-strong-32char-secret-key!!

# API Authentication
ALLOWED_API_KEYS=["your-secure-api-key-here"]

# CORS
ALLOWED_ORIGINS=["http://localhost:80","https://yourdomain.com"]

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://emailthreat:emailthreat@postgres:5432/emailthreat

# Redis
REDIS_URL=redis://redis:6379/0

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=emailthreat123

# ─── AI / LLM Keys ────────────────────────────────────────────────────────
# OpenAI (for LLM-powered text analysis)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Threat Intelligence Keys ────────────────────────────────────────────
# VirusTotal (free tier: 500 requests/day)
# Sign up at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# PhishTank (free with API key)
# Sign up at: https://www.phishtank.com/register.php
PHISHTANK_API_KEY=your-phishtank-api-key

# ─── Email Provider Integration ───────────────────────────────────────────
# Gmail API OAuth 2.0
# Create at: https://console.cloud.google.com/
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret

# Microsoft 365 / Graph API
# Create at: https://portal.azure.com/
MICROSOFT_CLIENT_ID=your-ms-client-id
MICROSOFT_CLIENT_SECRET=your-ms-client-secret
MICROSOFT_TENANT_ID=your-ms-tenant-id

# ─── SOAR Integration ─────────────────────────────────────────────────────
# Webhook URL for automated incident response
SOAR_WEBHOOK_URL=https://your-soar-platform.com/webhook
SOAR_API_KEY=your-soar-api-key

# ─── Analysis Thresholds ──────────────────────────────────────────────────
HIGH_RISK_THRESHOLD=0.75
MEDIUM_RISK_THRESHOLD=0.45
ANALYSIS_TIMEOUT_SECONDS=30

# ─── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── Monitoring ───────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin123
