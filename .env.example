# ────────────────────────────────────────────────────────────────────────────
# Multi-Agent Email Threat Analysis System – Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ────────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=changeme-use-a-strong-32char-secret-key!!

# ─── API Authentication ───────────────────────────────────────────────────
# Change this to a secure random string before going to production
ALLOWED_API_KEYS=["your-secure-api-key-here"]

# ─── CORS ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:80","https://yourdomain.com"]

# ─── PostgreSQL ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://emailthreat:emailthreat@postgres:5432/emailthreat

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Neo4j Graph Database ─────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=emailthreat123

# ─── Celery (Task Queue) ──────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── AI / LLM ─────────────────────────────────────────────────────────────
# OpenAI key enables GPT-powered deep text analysis (optional – system works
# without it using heuristics + custom ML model only)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Threat Intelligence ──────────────────────────────────────────────────
# VirusTotal – free tier: 500 requests/day
# Sign up: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# PhishTank – free with API key
# Sign up: https://www.phishtank.com/register.php
PHISHTANK_API_KEY=your-phishtank-api-key

# ─── Email Provider Integration (optional) ────────────────────────────────
# Gmail API OAuth 2.0 – https://console.cloud.google.com/
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret

# Microsoft 365 / Graph API – https://portal.azure.com/
MICROSOFT_CLIENT_ID=your-ms-client-id
MICROSOFT_CLIENT_SECRET=your-ms-client-secret
MICROSOFT_TENANT_ID=your-ms-tenant-id

# ─── SOAR Integration (optional) ─────────────────────────────────────────
SOAR_WEBHOOK_URL=https://your-soar-platform.com/webhook
SOAR_API_KEY=your-soar-api-key

# ─── Analysis Thresholds ──────────────────────────────────────────────────
HIGH_RISK_THRESHOLD=0.75
MEDIUM_RISK_THRESHOLD=0.45
ANALYSIS_TIMEOUT_SECONDS=30
RATE_LIMIT_PER_MINUTE=60

# ─── Custom ML Models ─────────────────────────────────────────────────────
# Directory where trained model checkpoints (.npz) are persisted.
# In Docker: mapped to the eta_ml_models named volume.
ML_MODEL_DIR=/app/ml_models
ML_PHISHING_THRESHOLD=0.5
ML_LLM_DETECT_THRESHOLD=0.5

# ─── RLHF Pipeline ────────────────────────────────────────────────────────
# Minimum analyst feedback records before auto-training triggers
RLHF_MIN_EXAMPLES=10
# Hours between automatic training cycles (Celery beat)
RLHF_TRAIN_INTERVAL_HOURS=6
RLHF_LEARNING_RATE=0.0005
RLHF_EPOCHS=15

# ─── Monitoring ───────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin123
