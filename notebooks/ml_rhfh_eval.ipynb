{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# ML & RLHF Evaluation Notebook\n",
        "\n",
        "This notebook evaluates the custom ML phishing and LLM-generation classifiers via the API.\n",
        "It computes accuracy, precision, recall, and F1 from a labeled dataset.\n",
        "\n",
        "**Prerequisites**\n",
        "- Backend API is running (\`http://localhost:8000\`)\n",
        "- API key available (set \`API_KEY\` below)\n",
        "- Dataset CSV with columns: \`subject, body_text, sender, label_phishing, label_llm\`\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 1) Install Dependencies"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "!pip install pandas scikit-learn requests"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 2) Configure API Access"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import os\n",
        "import requests\n",
        "import pandas as pd\n",
        "from sklearn.metrics import classification_report, confusion_matrix\n",
        "\n",
        "API_BASE = os.getenv('API_BASE', 'http://localhost:8000/api/v1')\n",
        "API_KEY = os.getenv('API_KEY', 'change-me-api-key')\n",
        "\n",
        "HEADERS = {\n",
        "    'Content-Type': 'application/json',\n",
        "    'X-API-Key': API_KEY,\n",
        "}\n",
        "\n",
        "print('API_BASE:', API_BASE)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 3) Load Labeled Dataset"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "DATASET_PATH = 'data/labeled_emails.csv'  # update this path\n",
        "df = pd.read_csv(DATASET_PATH)\n",
        "\n",
        "required_cols = {'subject', 'body_text', 'sender', 'label_phishing', 'label_llm'}\n",
        "missing = required_cols - set(df.columns)\n",
        "if missing:\n",
        "    raise ValueError(f'Missing required columns: {missing}')\n",
        "\n",
        "df = df.fillna('')\n",
        "df.head()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 4) Call /ml/batch-predict"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def chunked(iterable, size=50):\n",
        "    for idx in range(0, len(iterable), size):\n",
        "        yield iterable[idx:idx + size]\n",
        "\n",
        "results = []\n",
        "records = df.to_dict('records')\n",
        "\n",
        "for batch in chunked(records, size=50):\n",
        "    payload = {\n",
        "        'emails': [\n",
        "            {\n",
        "                'subject': row['subject'],\n",
        "                'body_text': row['body_text'],\n",
        "                'sender': row.get('sender', ''),\n",
        "                'headers': {},\n",
        "                'urls': row.get('urls', []),\n",
        "            }\n",
        "            for row in batch\n",
        "        ]\n",
        "    }\n",
        "    response = requests.post(f'{API_BASE}/ml/batch-predict', json=payload, headers=HEADERS)\n",
        "    response.raise_for_status()\n",
        "    data = response.json()\n",
        "    results.extend(data['results'])\n",
        "\n",
        "print(f'Got {len(results)} predictions')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 5) Evaluate Metrics"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "pred_phishing = [int(r['is_phishing']) for r in results]\n",
        "pred_llm = [int(r['is_llm_generated']) for r in results]\n",
        "\n",
        "true_phishing = df['label_phishing'].astype(int).tolist()\n",
        "true_llm = df['label_llm'].astype(int).tolist()\n",
        "\n",
        "print('Phishing classifier metrics')\n",
        "print(classification_report(true_phishing, pred_phishing, digits=3))\n",
        "print('Confusion matrix (phishing):')\n",
        "print(confusion_matrix(true_phishing, pred_phishing))\n",
        "\n",
        "print('\nLLM-generated classifier metrics')\n",
        "print(classification_report(true_llm, pred_llm, digits=3))\n",
        "print('Confusion matrix (LLM-generated):')\n",
        "print(confusion_matrix(true_llm, pred_llm))"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 6) Optional: Submit RLHF Feedback\n",
        "Use this to send analyst feedback back to the RLHF pipeline."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def submit_feedback(row, predicted):\n",
        "    payload = {\n",
        "        'analysis_id': row.get('analysis_id', 'eval-' + str(row.name)),\n",
        "        'subject': row['subject'],\n",
        "        'body_text': row['body_text'],\n",
        "        'sender': row.get('sender', ''),\n",
        "        'headers': {},\n",
        "        'urls': row.get('urls', []),\n",
        "        'predicted_verdict': predicted.get('verdict_suggestion', 'clean'),\n",
        "        'predicted_score': predicted.get('phishing_score', 0.0),\n",
        "        'predicted_llm': predicted.get('is_llm_generated', False),\n",
        "        'feedback_type': 'correct',\n",
        "        'corrected_verdict': None,\n",
        "        'analyst_id': 'eval-bot',\n",
        "        'notes': 'Automated evaluation feedback',\n",
        "    }\n",
        "    response = requests.post(f'{API_BASE}/ml/feedback', json=payload, headers=HEADERS)\n",
        "    response.raise_for_status()\n",
        "    return response.json()\n",
        "\n",
        "# Example: submit feedback for the first 5 rows\n",
        "for idx in range(min(5, len(df))):\n",
        "    result = submit_feedback(df.iloc[idx], results[idx])\n",
        "    print(result)"
      ]
    }
  ],
